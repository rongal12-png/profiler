# ── PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=wallet_intel

# ── RPC Endpoints (at least one required) ──────────────
# Get free endpoints from Alchemy, Infura, or QuickNode
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
AVALANCHE_RPC_URL=
FANTOM_RPC_URL=
BSC_RPC_URL=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HEDERA_RPC_URL=https://mainnet.hashio.io/api
TON_RPC_URL=https://toncenter.com/api/v2

# ── Optional: CoinGecko Pro API Key ───────────────────
# Without this, price lookups use the free tier (rate-limited)
COINGECKO_API_KEY=

# ── Admin API ─────────────────────────────────────────
# Required for /admin/* endpoints (settings, sanctions management)
ADMIN_API_KEY=changeme-replace-with-a-real-secret

# ── Website Password Protection ──────────────────────
# Password to access the web interface
SITE_PASSWORD=wallet123
